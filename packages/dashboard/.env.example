# AgentEconomy Dashboard Environment Variables

# API URL - your deployed API server (or http://localhost:3000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Cardano network: "preprod" or "mainnet"
NEXT_PUBLIC_NETWORK=preprod

# CardanoScan URL (auto-derived from network, but can override)
# NEXT_PUBLIC_CARDANOSCAN_URL=https://preprod.cardanoscan.io
